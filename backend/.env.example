# ── FaceTrack Environment Variables ─────────────────────────────────────────
# Copy this to .env and fill in your values. Never commit .env to git.

FLASK_ENV=development
JWT_SECRET_KEY=replace-with-a-long-random-string

# MongoDB (local or Atlas)
MONGO_URI=mongodb://localhost:27017/facetrack
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/facetrack

# AWS Rekognition (face recognition AI)
AWS_ACCESS_KEY=YOUR_AWS_ACCESS_KEY
AWS_SECRET_KEY=YOUR_AWS_SECRET_KEY
AWS_REGION=ap-south-1
AWS_COLLECTION_ID=facetrack-students

# MSG91 – SMS alerts to parents (India)
MSG91_API_KEY=YOUR_MSG91_KEY
MSG91_SENDER_ID=FTRACK

# Firebase Cloud Messaging – push notifications
FCM_SERVER_KEY=YOUR_FCM_SERVER_KEY

# Cloudinary – student photo storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
